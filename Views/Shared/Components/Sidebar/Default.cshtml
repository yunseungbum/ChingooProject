@model Chingoo.ViewModels.SidebarViewModel

<aside class="board-sidebar">

    <!-- =========================
         사용자 정보 영역
    ========================== -->
    <div class="my-info-box">

        @if (!Model.IsLogin)
        {
                <div class="text-center py-3">
                    <div class="my-info-title mb-2">내 정보</div>
                    <p class="text-muted small mb-3">로그인이 필요합니다</p>

                    <a asp-controller="Account"
                       asp-action="Login"
                       class="btn btn-primary w-100">
                        로그인
                    </a>
                </div>
        }
        else
        {
                <div class="my-info-title">내 정보</div>

                <div class="my-info-row">
                    <span>팀명</span>
                    <strong>@Model.NickName</strong>
                </div>

                <div class="my-info-row">
                    <span>지역</span>
                    <strong>@Model.Region</strong>
                </div>

                <div class="my-info-row">
                    <span>온도</span>
                    <strong>@Model.SoccerTemperature°C</strong>
                </div>

                <div class="mt-3">
                    <a asp-controller="Post"
                       asp-action="Create"
                       class="btn btn-success w-100">
                        게시글 작성
                    </a>
                    <a asp-controller="Post"
                       asp-action="Manage"
                       class="btn btn-outline-success w-100 mt-2">
                        게시글 관리
                    </a>
                </div>

        }

    </div>

    <!-- =========================
         메뉴 영역 (고정 데이터)
    ========================== -->
    <nav class="mt-3">

        <!-- 공지사항 -->
        <a asp-controller="Notice"
           asp-action="Index"
           class="sidebar-link">
            ▣ 공지사항
        </a>

        <!-- 커뮤니티 -->
        <a asp-controller="Community"
           asp-action="Index"
           class="sidebar-link">
            ▣ 커뮤니티
        </a>

     <!-- 축구 매치 -->
<details class="mt-2">
    <summary class="sidebar-summary">▣ 축구 매치</summary>

            @foreach (var day in Model.Days)
            {
            <details>
                <summary>@day</summary>

                <div class="board-region-list">
                        @foreach (var region in Model.Regions)
                        {
                            <a asp-controller="Post"
                               asp-action="Index"
                               asp-route-boardType="축구 매치"
                               asp-route-day="@day"
                               asp-route-region="@region"
                               class="sidebar-link">
                                @region
                            </a>
                        }
                </div>
            </details>
            }
</details>

<!-- 용병 모집 -->
<details class="mt-2">
    <summary class="sidebar-summary">▣ 용병 모집</summary>

            @foreach (var day in Model.Days)
            {
            <details>
                <summary>@day</summary>

                <div class="board-region-list">
                        @foreach (var region in Model.Regions)
                        {
                            <a asp-controller="Post"
                               asp-action="Index"
                               asp-route-boardType="용병 모집"
                               asp-route-day="@day"
                               asp-route-region="@region"
                               class="sidebar-link">
                                @region
                            </a>
                        }
                </div>
            </details>
            }
</details>

<!-- 팀원 모집 -->
<details class="mt-2">
    <summary class="sidebar-summary">▣ 팀원 모집</summary>

            @foreach (var day in Model.Days)
            {
            <details>
                <summary>@day</summary>

                <div class="board-region-list">
                        @foreach (var region in Model.Regions)
                        {
                            <a asp-controller="Post"
                               asp-action="Index"
                               asp-route-boardType="팀원 모집"
                               asp-route-day="@day"
                               asp-route-region="@region"
                               class="sidebar-link">
                                @region
                            </a>
                        }
                </div>
            </details>
            }
</details>

    </nav>

</aside>
