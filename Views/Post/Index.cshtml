@using Chingoo.Common
@model List<Chingoo.Models.Post>

<h2 class="mb-3">게시글 목록</h2>

<div class="card mb-3 p-3">

    <form method="get" asp-action="Index" class="row g-2 align-items-end">

        <input type="hidden" name="boardType" value="@ViewBag.BoardType" />

        <div class="col-md-2">
            <label class="form-label">게시판</label>
            <input type="text"
                   class="form-control"
                   value="@ViewBag.BoardType"
                   disabled />
        </div>

        <div class="col-md-2">
            <label class="form-label">평일 / 주말</label>
            <select name="day" class="form-select">
                <option value="">전체</option>
                @foreach (var day in BoardOptions.Days)
                {
                    <option value="@day" selected="@(ViewBag.Day == day)">@day</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">지역</label>
            <select name="region" class="form-select">
                <option value="">전체 지역</option>
                @foreach (var region in BoardOptions.Regions)
                {
                    <option value="@region" selected="@(ViewBag.Region == region)">@region</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">시간</label>
            <select name="time" class="form-select">
                <option value="">전체 시간</option>
                @foreach (var time in BoardOptions.Times)
                {
                    <option value="@time" selected="@(ViewBag.Time == time)">@time</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                검색
            </button>
        </div>

    </form>

</div>

@if (!Model.Any())
{
    <p class="text-muted">등록된 게시글이 없습니다.</p>
}
else
{
    foreach (var item in Model)
    {
        <a asp-controller="Post"
           asp-action="Details"
           asp-route-id="@item.Id"
           class="text-decoration-none text-dark">

            <div class="card mb-3 shadow-sm">

                <div class="card-body">

                    <h5 class="fw-bold mb-2">
                        @item.Title
                    </h5>

                    <div class="d-flex justify-content-between text-muted small">

                        <div>
                            작성자: <strong>@item.User.TeamName</strong>
                            |
                            날짜: @item.DayType
                            |
                            시간: @item.TimeSlot
                            |
                            장소: @item.Region
                        </div>

                        <div>
                            @item.CreatedAt.ToString("yyyy-MM-dd")
                        </div>

                    </div>

                </div>

            </div>

        </a>
    }
}
