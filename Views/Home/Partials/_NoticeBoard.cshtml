@model List<Chingoo.Models.Notice>

<div class="notice-board">
    <div class="notice-board-header">
        <h2>공지사항</h2>
        <a asp-controller="Notice" asp-action="Index">더보기</a>
    </div>

    <div class="notice-list">
        @if (!Model.Any())
        {
                <div class="notice-item">
                    <span class="notice-title">등록된 공지사항이 없습니다.</span>
                    <span class="notice-date"></span>
                </div>
        }
        else
        {
            foreach (var notice in Model)
            {
                        <a asp-controller="Notice"
                           asp-action="Details"
                           asp-route-id="@notice.Id"
                           class="notice-item">
                            <span class="notice-title">@notice.Title</span>
                            <span class="notice-date">@notice.CreatedAt.ToString("yyyy.MM.dd")</span>
                        </a>
            }
        }
    </div>
</div>