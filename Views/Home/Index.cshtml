@model Chingoo.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "홈";
}

<div class="home-board-layout">

    <section class="board-content" aria-label="공지사항">

        <div class="card shadow-sm border-0">

            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">공지사항</h4>

                <a asp-controller="Notice"
                   asp-action="Index"
                   class="btn btn-outline-primary btn-sm">
                    전체보기
                </a>
            </div>

            <div class="card-body p-0">
                @await Html.PartialAsync("Partials/_NoticeBoard", Model.Notices)
            </div>

        </div>

        <div class="home-community-panel">
            <div class="home-community-header">
                <h5>커뮤니티</h5>

                <a asp-controller="Community"
                   asp-action="Index">
                    더보기
                </a>
            </div>

            <div class="home-community-list">
                @if (!Model.CommunityPosts.Any())
                {
                    <div class="home-community-empty">
                        등록된 커뮤니티 게시글이 없습니다.
                    </div>
                }
                else
                {
                    foreach (var post in Model.CommunityPosts)
                    {
                        <a asp-controller="Community"
                           asp-action="Details"
                           asp-route-id="@post.Id"
                            class="home-community-item">
                            <span class="home-community-main">
                                <span class="home-community-title">@post.Title</span>
                            </span>
                            <span class="home-community-date">@post.CreatedAt.ToString("MM.dd HH:mm")</span>
                        </a>
                    }
                }
            </div>
        </div>

    </section>

</div>
