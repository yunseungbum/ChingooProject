@model Chingoo.Models.CommunityPost

@{
    ViewData["Title"] = "커뮤니티 글쓰기";
}

<h2 class="mb-3">커뮤니티 글쓰기</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Title" class="form-label">제목</label>
        <input asp-for="Title" class="form-control" placeholder="제목을 입력하세요." />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Content" class="form-label">내용</label>
        <textarea asp-for="Content"
                  class="form-control"
                  style="height: 300px;"
                  placeholder="내용을 입력하세요."></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">목록</a>
        <button type="submit" class="btn btn-primary">등록</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
