@model Chingoo.Models.CommunityPost

@{
    ViewData["Title"] = "커뮤니티 상세";

    var commentSort = ViewBag.CommentSort as string ?? "oldest";
    var allComments = ViewBag.Comments as List<Chingoo.Models.Comment> ?? new List<Chingoo.Models.Comment>();
    var comments = allComments.Where(x => x.ParentCommentId == null);
    comments = commentSort == "latest"
        ? comments.OrderByDescending(x => x.CreatedAt)
        : comments.OrderBy(x => x.CreatedAt);
    var currentUserIdValue = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var currentUserId = int.TryParse(currentUserIdValue, out var parsedCurrentUserId) ? parsedCurrentUserId : 0;
    var isAdmin = User.Identity?.Name == "admin";
    var isCommunityAuthor = currentUserId == Model.UserId;
    var canManageCommunity = isCommunityAuthor || isAdmin;
}

<div class="card shadow-sm post-card">

    <div class="card-body">

        @if (canManageCommunity)
        {
            <div class="d-flex justify-content-end gap-2 mb-3">
                <form asp-action="Delete"
                      asp-route-id="@Model.Id"
                      method="post"
                      onsubmit="return confirm('게시글을 삭제하시겠습니까? 관련 댓글과 대댓글도 모두 삭제됩니다.');">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-outline-danger btn-sm">
                        삭제
                    </button>
                </form>
            </div>
        }

        <h3 class="mb-3">@Model.Title</h3>

        <div class="text-muted small mb-3">
            작성자: <strong>@Model.User.TeamName</strong>
        </div>

        <hr />

        <div class="mt-3 post-content">@Model.Content</div>

        <div class="text-end text-muted small mt-4">
            @Model.CreatedAt.ToString("MM.dd HH:mm")
        </div>

    </div>

</div>

<section class="comment-panel">
    <div class="comment-panel-header">
        <div class="comment-sort">
            <a asp-action="Details"
               asp-route-id="@Model.Id"
               asp-route-commentSort="oldest"
               class="@(commentSort == "oldest" ? "active" : "")">
                등록순
            </a>

            <a asp-action="Details"
               asp-route-id="@Model.Id"
               asp-route-commentSort="latest"
               class="@(commentSort == "latest" ? "active" : "")">
                최신순
            </a>
        </div>

        <span class="comment-count">댓글 @allComments.Count(x => x.ParentCommentId == null)</span>
    </div>

    <div class="comment-list">
        @foreach (var comment in comments)
        {
            var replyFormId = $"community-reply-form-{comment.Id}";
            var replies = commentSort == "latest"
                ? comment.Replies.OrderByDescending(x => x.CreatedAt)
                : comment.Replies.OrderBy(x => x.CreatedAt);

            <article class="comment-item">
                <div class="comment-body">
                    <div class="comment-author-row">
                        <strong>@comment.User.TeamName</strong>
                        @if (comment.UserId == Model.UserId)
                        {
                            <span class="author-badge">작성자</span>
                        }
                        <span>@comment.CreatedAt.ToString("MM.dd HH:mm")</span>
                    </div>

                    <div class="comment-content">@comment.Content</div>

                    @if (isAdmin || comment.UserId == currentUserId)
                    {
                        <form asp-action="DeleteComment"
                              method="post"
                              class="d-inline"
                              onsubmit="return confirm('댓글을 삭제하시겠습니까? 대댓글도 함께 삭제됩니다.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="communityPostId" value="@Model.Id" />
                            <input type="hidden" name="commentId" value="@comment.Id" />
                            <button type="submit" class="comment-reply-toggle">삭제</button>
                        </form>
                    }

                    @if (isCommunityAuthor)
                    {
                        <button type="button"
                                class="comment-reply-toggle"
                                data-reply-target="@replyFormId">
                            답글
                        </button>
                    }

                    @if (comment.Replies.Any())
                    {
                        <div class="reply-list">
                            @foreach (var reply in replies)
                            {
                                <article class="comment-item reply-item">
                                    <div class="comment-body">
                                        <div class="comment-author-row">
                                            <strong>@reply.User.TeamName</strong>
                                            @if (reply.UserId == Model.UserId)
                                            {
                                                <span class="author-badge">작성자</span>
                                            }
                                            <span>@reply.CreatedAt.ToString("MM.dd HH:mm")</span>
                                        </div>

                                        <div class="comment-content">@reply.Content</div>

                                        @if (isAdmin || reply.UserId == currentUserId)
                                        {
                                            <form asp-action="DeleteComment"
                                                  method="post"
                                                  class="d-inline"
                                                  onsubmit="return confirm('댓글을 삭제하시겠습니까?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="communityPostId" value="@Model.Id" />
                                                <input type="hidden" name="commentId" value="@reply.Id" />
                                                <button type="submit" class="comment-reply-toggle">삭제</button>
                                            </form>
                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    }

                    @if (isCommunityAuthor)
                    {
                        <form asp-action="CreateComment"
                              method="post"
                              class="reply-form d-none"
                              id="@replyFormId">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="communityPostId" value="@Model.Id" />
                            <input type="hidden" name="parentCommentId" value="@comment.Id" />

                            <textarea name="content"
                                      class="form-control"
                                      rows="2"
                                      placeholder="답글을 입력하세요."></textarea>

                            <div class="comment-form-actions">
                                <button type="submit" class="btn btn-outline-secondary btn-sm">답글 등록</button>
                            </div>
                        </form>
                    }
                </div>
            </article>
        }

        @if (!allComments.Any())
        {
            <div class="comment-empty">
                아직 댓글이 없습니다.
            </div>
        }
    </div>

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <form asp-action="CreateComment" method="post" class="comment-form">
            @Html.AntiForgeryToken()

            <input type="hidden" name="communityPostId" value="@Model.Id" />

            <textarea name="content"
                      class="form-control"
                      rows="2"
                      placeholder="댓글을 입력하세요."></textarea>

            <div class="comment-form-actions">
                <button type="submit" class="btn btn-primary btn-sm">댓글 등록</button>
            </div>
        </form>
    }
    else
    {
        <div class="comment-empty">
            댓글을 작성하려면 로그인이 필요합니다.
        </div>
    }
</section>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">목록</a>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".comment-reply-toggle").forEach((button) => {
            button.addEventListener("click", () => {
                const targetId = button.getAttribute("data-reply-target");
                const form = document.getElementById(targetId);

                if (!form) {
                    return;
                }

                form.classList.toggle("d-none");
            });
        });
    </script>
}
