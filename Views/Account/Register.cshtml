@model Chingoo.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "회원가입";
}

<section class="account-page">
    <div class="account-card">

        <h2 class="text-center mb-4">회원가입</h2>

        <form asp-controller="Account" asp-action="Register" method="post">

            <div class="mb-3">
                <label asp-for="LoginId" class="form-label"></label>

                <div class="input-group">
                    <input asp-for="LoginId"
                           class="form-control"
                           autocomplete="username" />

                    <button type="button"
                            class="btn btn-outline-secondary"
                            id="btnCheckId">
                        중복확인
                    </button>
                </div>

                <span asp-validation-for="LoginId" class="text-danger"></span>
                <small id="checkIdResult"></small>
            </div>

            <div class="mb-3">
                <label asp-for="TeamName" class="form-label"></label>
                <input asp-for="TeamName" class="form-control" />
                <span asp-validation-for="TeamName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email"
                       class="form-control"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword"
                       type="password"
                       class="form-control"
                       autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Region" class="form-label"></label>

                <select asp-for="Region" class="form-select">
                    <option value="">지역을 선택하세요.</option>
                    <option value="서울 북부">서울 북부</option>
                    <option value="서울 남부">서울 남부</option>
                    <option value="인천, 부천">인천, 부천</option>
                    <option value="경기 북부">경기 북부</option>
                    <option value="경기 남부">경기 남부</option>
                </select>

                <span asp-validation-for="Region" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success w-100">
                회원가입
            </button>

        </form>

    </div>
</section>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />

        <script>
            $("#btnCheckId").click(function () {

                const loginId = $("#LoginId").val();

                if (loginId.trim() === "") {
                    $("#checkIdResult")
                        .text("아이디를 입력해주세요.")
                        .css("color", "red");
                    return;
                }

                $.get("/Account/CheckLoginId",
                    { loginId: loginId },
                    function (result) {

                        $("#checkIdResult")
                            .text(result.message)
                            .css("color", result.available ? "green" : "red");
                    });
            });
        </script>
}