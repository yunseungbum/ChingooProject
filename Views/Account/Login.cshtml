@{
    ViewData["Title"] = "로그인";
}

<section class="account-page">
    <div class="account-card">
        <h1>로그인</h1>
        <form>
            <div class="mb-3">
                <label for="userId" class="form-label">아이디</label>
                <input id="userId" name="UserId" class="form-control" autocomplete="username" />
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">비밀번호</label>
                <input id="password" name="Password" type="password" class="form-control" autocomplete="current-password" />
            </div>
            <button type="button" class="btn btn-primary w-100">로그인</button>
        </form>
        <a class="btn btn-outline-secondary w-100 mt-3" asp-controller="Account" asp-action="Register">회원가입</a>
    </div>
</section>
