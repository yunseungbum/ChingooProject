@model Chingoo.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "로그인";
}

<section class="account-page">
    <div class="account-card">
        <form asp-action="Login" asp-controller="Account" method="post">

            <div class="mb-3">
                <label asp-for="LoginId" class="form-label"></label>
                <input asp-for="LoginId" class="form-control" autocomplete="username" />
                <span asp-validation-for="LoginId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success w-100">로그인</button>

        </form>

        <!-- 👇 추가된 부분 -->
        <div class="text-center mt-3">
            <span class="text-muted">계정이 없으신가요?</span>
            <div class="mt-2">
                <a asp-controller="Account"
                   asp-action="Register"
                   class="btn btn-outline-primary w-100">
                    회원가입
                </a>
            </div>
        </div>

    </div>
</section>