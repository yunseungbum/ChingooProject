@model Chingoo.Models.Notice

@{
    ViewData["Title"] = "공지사항 수정";
}

<h2 class="mb-3">공지사항 수정</h2>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Title" class="form-label">제목</label>
        <input asp-for="Title" class="form-control" placeholder="공지사항 제목을 입력하세요." />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Content" class="form-label">내용</label>
        <textarea asp-for="Content"
                  class="form-control"
                  style="height: 300px;"
                  placeholder="공지사항 내용을 입력하세요."></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">취소</a>
        <button type="submit" class="btn btn-primary">수정</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
